// ─────────────────────────────────────────────────────────────────────────────
// CLI: JVM only (captal command-line tool)
// ─────────────────────────────────────────────────────────────────────────────

object cli extends BaseModule:
  def moduleDeps = Seq(provision)
  def mvnDeps = Seq(
    mvn"dev.zio::zio-cli:0.8.0",
    mvn"io.circe::circe-yaml:0.16.0",
    mvn"software.amazon.awssdk:s3:2.29.51",
    mvn"software.amazon.awssdk:ecs:2.29.51",
    mvn"software.amazon.awssdk:elasticloadbalancingv2:2.29.51",
    mvn"software.amazon.awssdk:ecr:2.29.51",
    mvn"software.amazon.awssdk:cloudfront:2.29.51",
    mvn"software.amazon.awssdk:cloudwatchlogs:2.29.51",
    mvn"org.slf4j:slf4j-nop:1.7.36")
  def mainClass = Some("whitelabel.captal.cli.Main")

  // Wrappers swap a freshly-downloaded captal.jar.new into place BEFORE launching Java.
  // Required on Windows where the running JVM locks the jar so `captal update` can't
  // replace it in-place; safe no-op on Linux/macOS.
  private val bashWrapper = """#!/usr/bin/env bash
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$SCRIPT_DIR/captal.jar.new" ]; then
  mv -f "$SCRIPT_DIR/captal.jar.new" "$SCRIPT_DIR/captal.jar"
fi
exec java -jar "$SCRIPT_DIR/captal.jar" "$@"
"""

  private val batWrapper = """@echo off
setlocal
set "SCRIPT_DIR=%~dp0"
if exist "%SCRIPT_DIR%captal.jar.new" (
  move /Y "%SCRIPT_DIR%captal.jar.new" "%SCRIPT_DIR%captal.jar" >nul
)
java -jar "%SCRIPT_DIR%captal.jar" %*
"""

  /** Bundle CLI release artifacts (JAR + cross-platform wrappers).
    * Output: out/cli/releaseAssets.dest/{captal.jar, captal, captal.bat}
    */
  def releaseAssets = Task:
    val dest = Task.dest
    os.copy.over(assembly().path, dest / "captal.jar")
    os.write.over(dest / "captal", bashWrapper)
    os.perms.set(dest / "captal", "rwxr-xr-x")
    os.write.over(dest / "captal.bat", batWrapper)
    PathRef(dest)

  /** Publish CLI release to S3 under both versioned and latest prefixes.
    * Usage: ./mill cli.publishS3 --bucket captal-cli-releases --version 1.0.0
    * Operator must run `aws sso login` or have AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY set.
    */
  def publishS3(bucket: String, version: String) = Task.Command:
    val src = releaseAssets().path
    val files = Seq(
      "captal.jar" -> "application/java-archive",
      "captal"     -> "text/x-shellscript",
      "captal.bat" -> "application/bat")
    val prefixes = Seq(s"s3://$bucket/v$version", s"s3://$bucket/latest")
    for
      prefix         <- prefixes
      (name, ctype)  <- files
    do
      val args = Seq(
        "aws", "s3", "cp",
        (src / name).toString,
        s"$prefix/$name",
        "--content-type", ctype)
      println(s"[publish] $name -> $prefix/$name")
      val result = os.proc(args).call(check = false, stderr = os.Pipe)
      if result.exitCode != 0 then
        sys.error(s"[publish] aws s3 cp failed for $name: ${result.err.trim()}")

    // Publish version.txt at both prefixes — read by `captal update` to detect new releases.
    val versionFile = src / "version.txt"
    os.write.over(versionFile, version)
    for prefix <- prefixes do
      val args = Seq(
        "aws", "s3", "cp",
        versionFile.toString,
        s"$prefix/version.txt",
        "--content-type", "text/plain")
      println(s"[publish] version.txt -> $prefix/version.txt")
      val result = os.proc(args).call(check = false, stderr = os.Pipe)
      if result.exitCode != 0 then
        sys.error(s"[publish] aws s3 cp failed for version.txt: ${result.err.trim()}")
    println(s"[publish] uploaded captal v$version to $bucket")

  /** Install the CLI locally to ~/.local/bin/ (Linux/macOS) for development convenience.
    * Usage: ./mill cli.installLocal
    */
  def installLocal() = Task.Command:
    val src = releaseAssets().path
    val target = os.home / ".local" / "bin"
    os.makeDir.all(target)
    os.copy.over(src / "captal.jar", target / "captal.jar")
    os.copy.over(src / "captal", target / "captal")
    os.perms.set(target / "captal", "rwxr-xr-x")
    println(s"[installLocal] captal installed to $target")
    println(s"[installLocal] ensure $target is on your PATH")

// ─────────────────────────────────────────────────────────────────────────────
// Client: JS only (Laminar app)
// ─────────────────────────────────────────────────────────────────────────────

object client extends BaseJSModule:
  def moduleDeps = Seq(`core-js`, `endpoints-js`)
  def mvnDeps = Seq(
    mvn"com.raquo::laminar::17.2.0",
    mvn"com.raquo::waypoint::9.0.0",
    mvn"io.github.cquiroz::scala-java-time::2.6.0")

  // Generate BuildInfo with environment at build time
  def generatedSources: T[Seq[PathRef]] = Task:
    val env = Task.env.getOrElse("ENVIRONMENT", "production")
    val isDevMode = env == "dev"
    val dest = Task.dest / "BuildInfo.scala"
    os.write(
      dest,
      s"""package whitelabel.captal.client
         |
         |object BuildInfo:
         |  val environment: String = "$env"
         |  val isDevMode: Boolean = $isDevMode
         |""".stripMargin
    )
    Seq(PathRef(Task.dest))

  private def gzipFile(src: os.Path, dest: os.Path): Unit =
    val in = java.io.FileInputStream(src.toIO)
    val out = java.util.zip.GZIPOutputStream(java.io.FileOutputStream(dest.toIO))
    try
      val buf = new Array[Byte](8192)
      var n = in.read(buf)
      while n > 0 do
        out.write(buf, 0, n)
        n = in.read(buf)
    finally
      out.close()
      in.close()

  def clientAssets: T[PathRef] = Task.Source(moduleDir / "assets")
  def clientTemplate: T[PathRef] = Task.Source(moduleDir / "index.html.template")

  /** Build production bundle and gzip assets.
    * Usage: ./mill client.bundle
    * Output: out/client/bundle.dest/
    */
  def bundle = Task:
    val src = fullLinkJS().dest.path
    val assets = clientAssets().path
    val template = clientTemplate().path
    val dest = Task.dest

    // Copy assets
    os.copy(src / "main.js", dest / "main.js")
    os.copy(assets / "styles.css", dest / "styles.css")
    os.copy(assets / "brand-icon.svg", dest / "brand-icon.svg")

    // Render index.html from template with relative paths so the browser resolves them
    // against the current directory (which lives at https://<host>/<slug>/ in prod).
    renderIndex(
      template,
      dest / "index.html",
      jsPath = "./main.js.gz",
      cssPath = "./styles.css.gz"
    )

    // Gzip JS and CSS
    gzipFile(dest / "main.js", dest / "main.js.gz")
    gzipFile(dest / "styles.css", dest / "styles.css.gz")

    PathRef(dest)

  /** Publish the bundle to S3 under `<bucket>/<prefix>/`. Replaces 4 manual `aws s3 cp`
    * invocations and ensures Content-Type / Content-Encoding metadata stay consistent.
    *
    * Usage: `./mill client.publishS3 --bucket captal-dev-assets --prefix bundle`
    *        Optional: `--region us-east-1` (default).
    *
    * Operator must run `aws sso login` or have AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY set.
    */
  def publishS3(bucket: String, prefix: String, region: String = "us-east-1") = Task.Command:
    val src = bundle().path
    val normalizedPrefix = prefix.stripSuffix("/")
    val destBase = s"s3://$bucket/$normalizedPrefix"
    // (name, content-type, content-encoding)
    val files: Seq[(String, String, Option[String])] = Seq(
      ("index.html",     "text/html; charset=utf-8", None),
      ("brand-icon.svg", "image/svg+xml",            None),
      ("main.js.gz",     "application/javascript",   Some("gzip")),
      ("styles.css.gz",  "text/css",                 Some("gzip")))
    for (name, ctype, enc) <- files do
      val baseArgs = Seq(
        "aws", "s3", "cp",
        (src / name).toString,
        s"$destBase/$name",
        "--region", region,
        "--content-type", ctype)
      val args = enc.fold(baseArgs)(e => baseArgs ++ Seq("--content-encoding", e))
      println(s"[publish] $name -> $destBase/$name")
      val result = os.proc(args).call(check = false, stderr = os.Pipe)
      if result.exitCode != 0 then
        sys.error(s"[publish] aws s3 cp failed for $name: ${result.err.trim()}")
    println(s"[publish] uploaded bundle to $destBase")

