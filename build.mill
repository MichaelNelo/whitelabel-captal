// ─────────────────────────────────────────────────────────────────────────────
// Helpers
// ─────────────────────────────────────────────────────────────────────────────

/** Render index.html.template replacing {{JS_PATH}} and {{CSS_PATH}} placeholders. */
private def renderIndex(templatePath: os.Path, destPath: os.Path, jsPath: String, cssPath: String): Unit =
  val template = os.read(templatePath)
  val rendered = template
    .replace("{{JS_PATH}}", jsPath)
    .replace("{{CSS_PATH}}", cssPath)
  os.write.over(destPath, rendered)

/** Ensure an rqlite Docker container is running. Starts one if needed. */
private def ensureRqlite(containerName: String, hostPort: Int): String =
  // Check Docker is available
  println(s"[rqlite] Checking Docker availability...")
  val dockerCheck = os.proc("docker", "info").call(check = false, stderr = os.Pipe)
  if dockerCheck.exitCode != 0 then
    sys.error(s"Docker is not running or not accessible: ${dockerCheck.err.trim()}")

  // Check if container is already running
  println(s"[rqlite] Checking for existing container '$containerName'...")
  val running = os
    .proc("docker", "ps", "-q", "-f", s"name=$containerName")
    .call()
    .out
    .trim()

  if running.nonEmpty then
    println(s"[rqlite] Container '$containerName' already running")
  else
    // Clean up any stopped container with the same name
    os.proc("docker", "rm", "-f", containerName).call(check = false, stderr = os.Pipe)

    // Check if port is already in use
    val portCheck = os.proc("docker", "ps", "-q", "-f", s"publish=$hostPort").call().out.trim()
    if portCheck.nonEmpty then
      sys.error(s"[rqlite] Port $hostPort is already in use by another container")

    println(s"[rqlite] Starting container '$containerName' on port $hostPort...")
    val startResult = os.proc(
      "docker",
      "run",
      "-d",
      "--name",
      containerName,
      "-p",
      s"$hostPort:4001",
      "-e",
      "SQLITE_EXTENSIONS=sqlean,misc",
      "rqlite/rqlite:8.36.2"
    ).call(check = false, stderr = os.Pipe)

    if startResult.exitCode != 0 then
      sys.error(s"[rqlite] Failed to start container: ${startResult.err.trim()}")

    println(s"[rqlite] Waiting for container to be ready...")
    var ready = false
    var attempts = 0
    while !ready && attempts < 30 do
      Thread.sleep(500)
      ready = scala.util
        .Try(os.proc("curl", "-sf", s"http://localhost:$hostPort/readyz").call())
        .isSuccess
      attempts += 1

    if !ready then
      // Grab container logs for diagnosis
      val logs = os
        .proc("docker", "logs", "--tail", "20", containerName)
        .call(check = false, stderr = os.Pipe)
      sys.error(
        s"[rqlite] Container '$containerName' failed to become ready after ${attempts * 500}ms.\n" +
          s"Container logs:\n${logs.out.trim()}\n${logs.err.trim()}"
      )

  println(s"[rqlite] '$containerName' ready on port $hostPort")
  s"jdbc:rqlite:http://localhost:$hostPort"

