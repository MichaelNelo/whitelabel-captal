// ─────────────────────────────────────────────────────────────────────────────
// Infra: JVM only
// ─────────────────────────────────────────────────────────────────────────────

object infra extends BaseModule:
  def moduleDeps = Seq(core, provision)
  def mvnDeps = Seq(
    mvn"dev.zio::zio:2.1.14",
    mvn"io.getquill::quill-jdbc-zio:4.8.6",
    mvn"com.github.geirolz::fly4s:1.0.8",
    mvn"dev.zio::zio-interop-cats:23.1.0.3",
    mvn"io.rqlite:rqlite-jdbc:9.1.2.1",
    mvn"ch.qos.logback:logback-classic:1.5.6",
    mvn"io.circe::circe-yaml:0.16.0")

  def migrate() = Task.Command:
    runMain("whitelabel.captal.infra.Migrate")()

  /** Build production base image captal-provision.
    * Usage: ./mill infra.dockerBuild <ecr-repo-uri> <tag>
    */
  def dockerBuild(repoUri: String, tag: String) = Task.Command:
    val root = moduleDir / os.up
    val fullTag = s"$repoUri:$tag"
    println(s"[docker] Building $fullTag ...")
    val result = os.proc(
      "docker", "build",
      "-f", (root / "Dockerfile.provision").toString,
      "-t", fullTag,
      root.toString
    ).call(check = false, stderr = os.Pipe)
    if result.exitCode != 0 then
      sys.error(s"[docker] Build failed:\n${result.err.trim()}")
    println(s"[docker] Built $fullTag")

  /** Push image to ECR. Operator must run `aws ecr get-login-password | docker login` first.
    * Usage: ./mill infra.dockerPush <ecr-repo-uri> <tag>
    */
  def dockerPush(repoUri: String, tag: String) = Task.Command:
    val fullTag = s"$repoUri:$tag"
    println(s"[docker] Pushing $fullTag ...")
    val result = os.proc("docker", "push", fullTag).call(check = false, stderr = os.Pipe)
    if result.exitCode != 0 then
      sys.error(s"[docker] Push failed:\n${result.err.trim()}")
    println(s"[docker] Pushed $fullTag")


// ─────────────────────────────────────────────────────────────────────────────
// API: JVM only (server implementation)
// ─────────────────────────────────────────────────────────────────────────────

object api extends BaseModule:
  def moduleDeps = Seq(core, endpoints, infra)
  def mvnDeps = Seq(
    mvn"com.softwaremill.sttp.tapir::tapir-zio-http-server:1.11.11",
    mvn"com.softwaremill.sttp.tapir::tapir-json-circe:1.11.11",
    mvn"dev.zio::zio-interop-cats:23.1.0.3")

  override def forkEnv: T[Map[String, String]] = Task:
    Map("PROVISION_DIR" -> defaultProvisionDir, "LOCATION_SLUG" -> defaultLocationSlug, "SHARED_DIR" -> defaultSharedDir) ++ super.forkEnv()

  // Render index.html from template for local development
  def copyIndex() = Task.Command:
    val root = moduleDir / os.up
    renderIndex(
      root / "client" / "index.html.template",
      root / "client" / "index.html",
      jsPath = "/out/client/fastLinkJS.dest/main.js",
      cssPath = "/assets/styles.css"
    )

  private val rqliteDevPort = 4001
  private val rqliteDevContainerName = "rqlite-dev"
  private val devProvisionBase = moduleDir / "resources" / "provision" / "dev"
  private val defaultProvisionDir = (devProvisionBase / "locations" / "cafe-centro").toString
  private val defaultSharedDir = (devProvisionBase / "shared").toString
  private val defaultLocationSlug = "cafe-centro"

  def rqliteSetup() = Task.Command:
    ensureRqlite(rqliteDevContainerName, rqliteDevPort)

  def stopRqlite() = Task.Command:
    os.proc("docker", "rm", "-f", rqliteDevContainerName).call(check = false)
    println("rqlite test container stopped")

  // Compile client before running server
  override def run(args: Task[Args] = Task.Anon(Args())) = Task.Command:
    copyIndex()()
    client.fastLinkJS()
    super.run(args)()

  /** Full dev workflow: rqlite + migrations + client + server.
    * Usage: ./mill api.dev
    *        ./mill api.dev --slug basic --dir /path/to/location --shared-dir /path/to/shared
    */
  def dev(
      slug: String = defaultLocationSlug,
      dir: String = defaultProvisionDir,
      sharedDir: String = defaultSharedDir) = Task.Command:
    println("[dev] Step 1/3: Ensuring rqlite container...")
    rqliteSetup()()
    println("[dev] Step 2/3: Running migrations...")
    infra.migrate()()
    println(s"[dev] Step 3/3: Starting server (location=$slug)...")
    copyIndex()()
    client.fastLinkJS()
    val cp = runClasspath().map(_.path.toString).mkString(java.io.File.pathSeparator)
    val mc = "whitelabel.captal.api.Main"
    val env = forkEnv() ++ Map(
      "PROVISION_DIR" -> dir,
      "LOCATION_SLUG" -> slug,
      "SHARED_DIR" -> sharedDir)
    os.proc("java", forkArgs(), "-cp", cp, mc).call(
      env = env,
      stdin = os.Inherit,
      stdout = os.Inherit,
      stderr = os.Inherit
    )

  object test extends ScalaTests with ScalafmtModule with ScalafixModule:
    def mvnDeps = Seq(
      mvn"dev.zio::zio-test:2.1.14",
      mvn"dev.zio::zio-test-sbt:2.1.14",
      mvn"com.softwaremill.sttp.tapir::tapir-sttp-stub-server:1.11.11")
    def testFramework = "zio.test.sbt.ZTestFramework"

    private val rqliteTestPort = 4011
    private val rqliteContainerName = "rqlite-test"

    override def forkEnv: T[Map[String, String]] = Task:
      val url = ensureRqlite(rqliteContainerName, rqliteTestPort)
      super.forkEnv() ++ Map("TEST_DB_URL" -> url)

    def stopRqlite() = Task.Command:
      os.proc("docker", "rm", "-f", rqliteContainerName).call(check = false)
      println("rqlite test container stopped")

  /** Build the dev Docker image (uses Dockerfile.api with SERVER_DEV_ENDPOINTS=true).
    * Usage: ./mill api.dockerBuildDev captal-dev 0.1.0
    */
  def dockerBuildDev(name: String, version: String) = Task.Command:
    val root = moduleDir / os.up
    val tag = s"$name:$version"
    println(s"[docker] Building $tag ...")
    val result = os.proc(
      "docker", "build",
      "-f", (root / "Dockerfile.api").toString,
      "--build-arg", "SERVER_DEV_ENDPOINTS=true",
      "-t", tag,
      root.toString
    ).call(check = false, stderr = os.Pipe)
    if result.exitCode != 0 then
      sys.error(s"[docker] Build failed:\n${result.err.trim()}")
    println(s"[docker] Built $tag")

  /** Build production base image captal-api.
    * Usage: ./mill api.dockerBuild <ecr-repo-uri> <tag>
    */
  def dockerBuild(repoUri: String, tag: String) = Task.Command:
    val root = moduleDir / os.up
    val fullTag = s"$repoUri:$tag"
    println(s"[docker] Building $fullTag ...")
    val result = os.proc(
      "docker", "build",
      "-f", (root / "Dockerfile.api").toString,
      "-t", fullTag,
      root.toString
    ).call(check = false, stderr = os.Pipe)
    if result.exitCode != 0 then
      sys.error(s"[docker] Build failed:\n${result.err.trim()}")
    println(s"[docker] Built $fullTag")

  /** Push image to ECR. Operator must run `aws ecr get-login-password | docker login` first.
    * Usage: ./mill api.dockerPush <ecr-repo-uri> <tag>
    */
  def dockerPush(repoUri: String, tag: String) = Task.Command:
    val fullTag = s"$repoUri:$tag"
    println(s"[docker] Pushing $fullTag ...")
    val result = os.proc("docker", "push", fullTag).call(check = false, stderr = os.Pipe)
    if result.exitCode != 0 then
      sys.error(s"[docker] Push failed:\n${result.err.trim()}")
    println(s"[docker] Pushed $fullTag")

